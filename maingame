def clear_screen():
    for widget in root.winfo_children():
        widget.destroy()


def current_stage():
    return STATIONS[player["station"]]


def settings():
    return DIFFICULTIES[game_state["difficulty"]]


def create_deck():
    new_deck = [
        {"rank": rank, "suit": suit}
        for suit in SUITS
        for rank in RANKS
    ]
    random.shuffle(new_deck)
    return new_deck


def draw_playing_card():
    global deck

    if not deck:
        deck = create_deck()

    return deck.pop()


def card_strength(rank):
    if rank in ["Ace", "2", "3", "4", "5"]:
        return 1

    if rank in ["6", "7", "8", "9", "10"]:
        return 2

    return 3


def card_modifier(card):
    strength = card_strength(card["rank"])

    if card["suit"] == "Hearts":
        return strength

    if card["suit"] == "Diamonds":
        return max(1, strength - 1)

    if card["suit"] == "Clubs":
        return -strength

    return -(strength + 1)


def plant_modifier(plant_name, base_result):
    uses = player["plant_uses"][plant_name]
    result = base_result
    note = ""

    if plant_name == "Switchgrass":
        if result < 0:
            result += 1
            note = "Switchgrass resilience reduced the loss by 1 tree."

    elif plant_name == "Poplar Trees":
        if uses == 0:
            result -= 1
            note = "New poplar needed time to establish: -1 tree."
        else:
            bonus = min(2, uses)
            result += bonus
            note = f"Established poplar added a +{bonus} tree bonus."

    elif plant_name == "Corn Stover":
        if uses == 0:
            result += 2
            note = "First corn-stover use received a +2 tree bonus."
        elif uses == 1:
            result += 1
            note = "Second corn-stover use received a +1 tree bonus."
        else:
            penalty = min(2, uses - 1)
            result -= penalty
            note = f"Repeated residue removal caused a -{penalty} tree penalty."

    return result, note


def farm_resistance_bonus(dilemma_name, result):
    farm_data = FARMS[player["farm"]]

    if dilemma_name in farm_data["resists"] and result < 0:
        improved = min(0, result + 2)
        prevented = improved - result

        return (
            improved,
            f"{player['farm']} prevented {prevented} tree loss.",
        )

    return result, ""


def get_current_dilemma():
    return game_state["current_dilemmas"][game_state["dilemma_index"]]


def prepare_turn():
    current_settings = settings()

    if game_state["turn"] >= current_settings["turn_limit"]:
        show_lose_screen("You ran out of time before reaching the biorefinery.")
        return

    game_state["turn"] += 1
    game_state["dilemma_index"] = 0
    game_state["current_card"] = None
    game_state["last_plant"] = None
    game_state["turn_tree_change"] = 0

    if (
        game_state["difficulty"] == "Easy"
        and game_state["turn"] % current_settings["event_every"] != 0
    ):
        selected = [NORMAL_CONDITIONS]
    else:
        available = DILEMMAS[current_stage()]
        count = min(current_settings["event_count"], len(available))
        selected = random.sample(available, count)

    game_state["current_dilemmas"] = selected
    show_dilemma_screen()


def check_tree_collapse():
    if player["trees"] <= 0:
        show_lose_screen("Your biomass supply collapsed to zero trees.")
        return True

    return False


def required_trees_for_current_stage():
    return ADVANCE_REQUIREMENTS[game_state["difficulty"]][current_stage()]


def production_die_change(plant_name, roll):
    return DICE_YIELDS[plant_name][roll]


def draw_die_face(canvas, value):
    """Draw a real six-sided die using a Tkinter Canvas."""
    canvas.delete("all")

    margin = 12
    size = 170
    canvas.create_rectangle(
        margin,
        margin,
        size - margin,
        size - margin,
        fill="white",
        outline="#222222",
        width=4,
    )

    positions = {
        "top_left": (48, 48),
        "top_right": (122, 48),
        "middle_left": (48, 85),
        "center": (85, 85),
        "middle_right": (122, 85),
        "bottom_left": (48, 122),
        "bottom_right": (122, 122),
    }

    pips = {
        1: ["center"],
        2: ["top_left", "bottom_right"],
        3: ["top_left", "center", "bottom_right"],
        4: ["top_left", "top_right", "bottom_left", "bottom_right"],
        5: ["top_left", "top_right", "center", "bottom_left", "bottom_right"],
        6: [
            "top_left",
            "top_right",
            "middle_left",
            "middle_right",
            "bottom_left",
            "bottom_right",
        ],
    }

    radius = 10
    for position_name in pips[value]:
        x, y = positions[position_name]
        canvas.create_oval(
            x - radius,
            y - radius,
            x + radius,
            y + radius,
            fill="#111111",
            outline="#111111",
        )


