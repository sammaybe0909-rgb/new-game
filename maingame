def draw_rules_visual(parent):
    """Draw a simple picture-like guide to the game turn."""
    visual = tk.Frame(
        parent,
        bg="#e7f0df",
        bd=3,
        relief="ridge",
    )
    visual.pack(fill="x", padx=18, pady=12)

    tk.Label(
        visual,
        text="ONE TURN AT A GLANCE",
        font=("Georgia", 16, "bold"),
        bg="#e7f0df",
        fg="#31572c",
    ).pack(pady=(10, 7))

    steps = tk.Frame(visual, bg="#e7f0df")
    steps.pack(pady=(0, 12))

    step_data = [
        ("1", "DILEMMA", "?"),
        ("2", "DRAW CARD", "♥ ♦ ♣ ♠"),
        ("3", "CHOOSE PLANT", "SW  PT  CS"),
        ("4", "ROLL DIE", "●  ●●  ●●●"),
        ("5", "CHECK TREES", "ADVANCE"),
    ]

    for column, (number, title, picture) in enumerate(step_data):
        card = tk.Frame(
            steps,
            width=105,
            height=105,
            bg="white",
            bd=2,
            relief="raised",
        )
        card.grid(row=0, column=column * 2, padx=4)
        card.grid_propagate(False)

        tk.Label(
            card,
            text=number,
            font=("Arial", 10, "bold"),
            bg="#31572c",
            fg="white",
            width=3,
        ).pack(pady=(6, 3))

        tk.Label(
            card,
            text=picture,
            font=("Arial", 13, "bold"),
            bg="white",
            wraplength=95,
        ).pack(pady=4)

        tk.Label(
            card,
            text=title,
            font=("Arial", 9, "bold"),
            bg="white",
            wraplength=95,
        ).pack(pady=2)

        if column < len(step_data) - 1:
            tk.Label(
                steps,
                text="→",
                font=("Arial", 18, "bold"),
                bg="#e7f0df",
                fg="#31572c",
            ).grid(row=0, column=column * 2 + 1, padx=1)


