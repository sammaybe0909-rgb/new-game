        bg="#f4f1df",
    ).pack(pady=(3, 3))

    plant_cards_frame = tk.Frame(root, bg="#f4f1df")
    plant_cards_frame.pack(pady=2)

    plant_buttons = []

    def choose_plant(plant_name):
        if game_state["current_card"] is None:
            messagebox.showwarning(
                "Draw First",
                "Draw a playing card before choosing a plant.",
            )
            return

        base_result = dilemma["outcomes"][plant_name]

        plant_result, plant_note = plant_modifier(
            plant_name,
            base_result,
        )

        farm_result, farm_note = farm_resistance_bonus(
            dilemma["name"],
            plant_result,
        )

        playing_card_change = card_modifier(
            game_state["current_card"]
        )

        final_change = farm_result + playing_card_change

        player["plant_uses"][plant_name] += 1
        game_state["last_plant"] = plant_name
        player["trees"] = max(
            0,
            player["trees"] + final_change,
        )
        game_state["turn_tree_change"] += final_change

        if final_change > 0:
            change_text = f"Gain {final_change} trees."
        elif final_change < 0:
            change_text = f"Lose {abs(final_change)} trees."
        else:
            change_text = "No trees gained or lost."

        card = game_state["current_card"]
        card_text = (
            f"{card['rank']} of {card['suit']} "
            f"({playing_card_change:+d})"
        )

        result_lines = [
            f"You chose {plant_name}.",
            f"Playing card: {card_text}",
            change_text,
        ]

        if plant_note:
            result_lines.append(plant_note)

        if farm_note:
            result_lines.append(farm_note)

        game_state["last_result"] = "\n".join(result_lines)
        game_state["last_lesson"] = dilemma["lesson"]
        game_state["current_card"] = None

        if check_tree_collapse():
            return

        show_choice_result_screen()

    for column, plant_name in enumerate(PLANTS):
        plant = PLANTS[plant_name]
        uses = player["plant_uses"][plant_name]

        plant_frame = tk.Frame(
            plant_cards_frame,
            width=270,
            height=155,
            bg="white",
            bd=4,
            relief="raised",
        )
        plant_frame.grid(row=0, column=column, padx=8)
        plant_frame.grid_propagate(False)

        tk.Label(
            plant_frame,
            text=plant["icon"],
            font=("Arial", 19, "bold"),
            bg="white",
        ).pack(pady=(5, 0))

        tk.Label(
            plant_frame,
            text=plant_name,
            font=("Georgia", 14, "bold"),
            bg="white",
        ).pack()

        tk.Label(
            plant_frame,
            text=plant["summary"],
            font=("Arial", 9, "italic"),
            bg="white",
            fg="#4d5b45",
        ).pack(pady=1)

        tk.Label(
            plant_frame,
            text=f"Used {uses} time(s)",
            font=("Arial", 9),
            bg="white",
        ).pack(pady=1)

        button = tk.Button(
            plant_frame,
            text="PLAY THIS CARD",
            font=("Arial", 9, "bold"),
            bg="#cccccc",
            state="disabled",
            command=lambda name=plant_name: choose_plant(name),
        )
        button.pack(pady=5)
        plant_buttons.append(button)

    def draw_card_action():
        if game_state["current_card"] is not None:
            return

        card = draw_playing_card()
        game_state["current_card"] = card

        symbol = SUIT_SYMBOLS[card["suit"]]
        color = "red" if card["suit"] in ["Hearts", "Diamonds"] else "black"

        card_label.config(
            text=f"{card['rank']}\n{symbol} {card['suit']}",
            fg=color,
        )

        draw_button.config(state="disabled")

        for button in plant_buttons:
            button.config(
                state="normal",
                bg="#91c788",
            )

    draw_button.config(command=draw_card_action)

    tk.Button(
        root,
        text="MAIN MENU",
        font=("Arial", 9),
        width=14,
        command=show_main_menu,
    ).pack(pady=6)


