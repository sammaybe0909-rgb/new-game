def show_dice_screen():
    clear_screen()
    root.configure(bg="#f4f1df")

    add_quick_rules_button()

    plant_name = game_state["last_plant"]
    required_trees = required_trees_for_current_stage()

    tk.Label(
        root,
        text="ROLL THE PRODUCTION DIE",
        font=("Georgia", 29, "bold"),
        bg="#f4f1df",
        fg="#3f7d44",
    ).pack(pady=(42, 10))

    tk.Label(
        root,
        text=(
            f"Production plant: {plant_name}\n"
            f"Current trees: {player['trees']} | "
            f"Needed to advance: {required_trees}"
        ),
        font=("Arial", 15, "bold"),
        bg="#f4f1df",
        justify="center",
    ).pack(pady=6)

    profile_text = {
        "Switchgrass": "Roll 1–2: +0 | 3–4: +1 | 5–6: +2",
        "Poplar Trees": "Roll 1: -2 | 2: -1 | 3–4: +1 | 5: +3 | 6: +4",
        "Corn Stover": "Roll 1: -2 | 2: +0 | 3–4: +2 | 5–6: +3",
    }[plant_name]

    tk.Label(
        root,
        text=profile_text,
        font=("Arial", 12),
        bg="#f4f1df",
        fg="#4d5b45",
    ).pack(pady=4)

    dice_canvas = tk.Canvas(
        root,
        width=170,
        height=170,
        bg="#f4f1df",
        highlightthickness=0,
    )
    dice_canvas.pack(pady=8)
    draw_die_face(dice_canvas, 1)

    result_label = tk.Label(
        root,
        text="Roll to determine this turn's biomass production.",
        font=("Arial", 15, "bold"),
        bg="#f4f1df",
        justify="center",
        wraplength=780,
    )
    result_label.pack(pady=8)

    continue_button = tk.Button(
        root,
        text="CONTINUE",
        font=("Arial", 14, "bold"),
        width=22,
        bg="#91c788",
        state="disabled",
    )
    continue_button.pack(pady=10)

    roll_button = tk.Button(
        root,
        text="ROLL PRODUCTION DIE",
        font=("Arial", 15, "bold"),
        width=22,
        height=2,
        bg="#ffd782",
    )
    roll_button.pack(pady=7)

    def continue_after_roll():
        current_settings = settings()

        if player["trees"] <= 0:
            show_lose_screen("Your biomass supply collapsed to zero trees.")
            return

        if game_state["turn_tree_change"] < 0:
            game_state["failed_turns"] += 1
        else:
            game_state["failed_turns"] = 0

        if game_state["failed_turns"] >= current_settings["failed_turn_limit"]:
            show_lose_screen(
                f"You suffered {current_settings['failed_turn_limit']} "
                "losing turns in a row."
            )
            return

        if current_stage() == "Biorefinery":
            if player["trees"] >= required_trees:
                show_win_screen()
            else:
                show_lose_screen(
                    "The biorefinery could not operate because you finished with "
                    f"fewer than {required_trees} trees."
                )
            return

        if player["trees"] >= required_trees:
            player["station"] += 1

        if game_state["turn"] >= current_settings["turn_limit"]:
            show_lose_screen(
                "You reached the turn limit before completing the journey."
            )
            return

        prepare_turn()

    def roll_die():
        roll = random.randint(1, 6)
        draw_die_face(dice_canvas, roll)

        tree_change = production_die_change(plant_name, roll)
        player["trees"] = max(0, player["trees"] + tree_change)
        game_state["turn_tree_change"] += tree_change

        if tree_change > 0:
            production_text = f"{plant_name} produced +{tree_change} trees."
        elif tree_change < 0:
            production_text = f"{plant_name} lost {abs(tree_change)} trees."
        else:
            production_text = f"{plant_name} produced no additional trees."

        if current_stage() == "Biorefinery":
            if player["trees"] >= required_trees:
                gate_text = (
                    f"You now have {player['trees']} trees, enough to operate "
                    "the biorefinery."
                )
            else:
                gate_text = (
                    f"You now have {player['trees']} trees, but the biorefinery "
                    f"requires {required_trees}."
                )
        elif player["trees"] >= required_trees:
            next_station = STATIONS[player["station"] + 1]
            gate_text = (
                f"Requirement met: {player['trees']}/{required_trees}. "
                f"You will advance to {next_station}."
            )
        else:
            gate_text = (
                f"Requirement not met: {player['trees']}/{required_trees}. "
                f"You will remain at {current_stage()}."
            )

        result_label.config(
            text=(
                f"You rolled {roll}.\n"
                f"{production_text}\n"
                f"{gate_text}"
            )
        )

        roll_button.config(state="disabled")
        continue_button.config(
            state="normal",
            command=continue_after_roll,
        )

    roll_button.config(command=roll_die)


