        root,
        text=f"Final trees: {player['trees']}",
        font=("Arial", 25, "bold"),
        bg="#e8f5e9",
        fg="#31572c",
    ).pack(pady=18)

    tk.Label(
        root,
        text=(
            f"Difficulty: {game_state['difficulty']}\n"
            f"Turns used: {game_state['turn']}"
        ),
        font=("Arial", 15),
        bg="#e8f5e9",
        justify="center",
    ).pack(pady=8)

    end_buttons()


def show_lose_screen(reason):
    clear_screen()
    root.configure(bg="#f8e7e7")

    tk.Label(
        root,
        text="GAME OVER",
        font=("Georgia", 36, "bold"),
        bg="#f8e7e7",
        fg="#8b2f2f",
    ).pack(pady=(75, 15))

    tk.Label(
        root,
        text=reason,
        font=("Arial", 18, "bold"),
        bg="#f8e7e7",
        wraplength=720,
        justify="center",
    ).pack(pady=14)

    tk.Label(
        root,
        text=(
            f"Trees remaining: {player['trees']}\n"
            f"Stage reached: {current_stage()}\n"
            f"Turns used: {game_state['turn']}"
        ),
        font=("Arial", 15),
        bg="#f8e7e7",
        justify="center",
    ).pack(pady=14)

    end_buttons()


def end_buttons():
    tk.Button(
        root,
        text="PLAY AGAIN",
        font=("Arial", 15, "bold"),
        width=20,
        bg="#91c788",
        command=show_setup_screen,
    ).pack(pady=13)

    tk.Button(
        root,
        text="MAIN MENU",
        font=("Arial", 14),
        width=20,
        command=show_main_menu,
    ).pack(pady=5)


